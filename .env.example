# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1
# MongoDB
MONGODB_URI=mongodb://localhost:27017/adcc
# Or for MongoDB Atlas
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ADCC
# Optional DNS override if your ISP/router blocks SRV lookups
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# Optional startup retry settings
# MONGODB_CONNECT_RETRIES=3
# MONGODB_CONNECT_RETRY_DELAY_MS=2000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# OTP Configuration
# Firebase Admin (if using Firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# OR Twilio (if using Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone

# Push Notifications
FIREBASE_SERVER_KEY=your-firebase-server-key

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# AWS S3 Image Upload
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
